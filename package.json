{
  "name": "compass-web",
  "version": "0.4.0-beta.1",
  "bin": "./dist/server.js",
  "scripts": {
    "format": "./compass/node_modules/.bin/prettier --config ./compass/.prettierrc.json --write \"src/**/*.{ts,tsx,js}\" \"*.js\" \"vendors/*.js\" ",
    "prebuild": "rm -rf dist",
    "build-client": "ELECTRON_OVERRIDE_DIST_PATH=/dev/null ELECTRON_SKIP_BINARY_DOWNLOAD=1 compass/node_modules/.bin/webpack",
    "bc": "npm run build-client",
    "build-client:production": "ELECTRON_OVERRIDE_DIST_PATH=/dev/null ELECTRON_SKIP_BINARY_DOWNLOAD=1 NODE_ENV=production compass/node_modules/.bin/webpack",
    "build-server": "rollup -c",
    "bs": "npm run build-server",
    "build-server:production": "NODE_ENV=production rollup -c",
    "build-auth": "cd auth-ui && npm run build",
    "build:all": "npm run build-client:production && npm run build-server:production && npm run build-auth",
    "start": "node app.js",
    "test": "mocha"
  },
  "author": "julmtz02",
  "license": "SSPL",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julmtz02/mongo-compass-web.git"
  },
  "homepage": "https://github.com/julmtz02/mongo-compass-web#readme",
  "bugs": {
    "url": "https://github.com/julmtz02/mongo-compass-web/issues"
  },
  "description": "MongoDB Compass that runs on a browser",
  "dependencies": {
    "@fastify/auth": "^5.0.2",
    "@fastify/basic-auth": "^6.2.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.2.0",
    "@fastify/view": "^11.1.0",
    "@fastify/websocket": "^11.1.0",
    "better-sqlite3": "^11.10.0",
    "eta": "^3.5.0",
    "fastify": "^5.3.3",
    "lodash": "^4.17.21",
    "lowdb": "^7.0.1",
    "mongodb": "^6.17.0",
    "mongodb-connection-string-url": "^3.0.2",
    "mongodb-schema": "^12.5.2",
    "node-cache": "^5.1.2",
    "openai": "^6.6.0",
    "papaparse": "^5.3.2",
    "stream-json": "^1.7.5",
    "strip-bom-stream": "^4.0.0",
    "webidl-conversions": "^8.0.1",
    "yargs": "^17.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/register": "^7.28.3",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.8",
    "@rollup/plugin-json": "^6.1.0",
    "copy-webpack-plugin": "^13.0.0",
    "mocha": "^11.7.5",
    "rollup": "^4.52.5"
  },
  "pnpm": {},
  "keywords": [
    "mongodb",
    "compass",
    "database",
    "GUI"
  ],
  "packageManager": "pnpm@10.12.1"
}
